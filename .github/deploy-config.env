# Non-secret settings for GitHub Actions deploy (merge to main).
# Omit DEPLOY_VCS_REPO here so the workflow appends git@github.com:${{ github.repository }}.git
# Use the CT's public routable IPv4 (same pattern as DomainSage deploy-config).
DEPLOY_LXC_CTID=210
DEPLOY_LXC_PATH=/var/www/holidaysage
DEPLOY_LXC_IP=87.117.209.197/26
DEPLOY_BASE=/var/www/holidaysage
DEPLOY_VCS_BRANCH=main
DEPLOY_LXC_SSH_USER=root
DEPLOY_LXC_SSH_PORT=22
DEPLOY_NGINX_SITE=holidaysage
