# Deploy-to-server defaults. Copy to .env.deploy (gitignored) and adjust if needed.
# Same host/network pattern as DomainSage / Road (dawn.phurix.com / 87.117.x).
# DEPLOY_LXC_IP must be the CT's routable IPv4 (with CIDR) so deploy.sh and GitHub Actions can SSH.
# Confirm the address in Proxmox before relying on it.

# Proxmox host SSH (optional; for run-setup-lxc-on-host.sh)
DEPLOY_SERVER_HOST=dawn.phurix.com
DEPLOY_SERVER_PATH=/home/admin/holidaysage
DEPLOY_SERVER_PORT=2222
DEPLOY_SERVER_USER=admin
# DEPLOY_PROXMOX_USER=root

# LXC: deploy connects directly to container (git hoist: clone -> staging -> activate).
# VMID must already exist on Proxmox (see: sudo pct list). If not, run ./scripts/run-setup-lxc-on-host.sh first.
DEPLOY_LXC_CTID=202
DEPLOY_LXC_PATH=/var/www/holidaysage
DEPLOY_LXC_NAME=holidaysage
# Next free address in the same /26 as DomainSage is typical; confirm in Proxmox.
DEPLOY_LXC_IP=87.117.209.197/26

DEPLOY_BASE=/var/www/holidaysage
DEPLOY_VCS_REPO=git@github.com:jpswade/holidaysage.git
# DEPLOY_VCS_BRANCH=main
DEPLOY_NGINX_SITE=holidaysage
# DEPLOY_SYSTEMD_PREFIX=holidaysage

# One-time: ./scripts/setup-deploy-key.sh → GitHub deploy key; ./scripts/add-deploy-key-to-container.sh
# LXC_SSH_PRIVATE_KEY_PATH=$HOME/.ssh/holidaysage-deploy
# DEPLOY_KEY_PATH=$HOME/.ssh/holidaysage-deploy
DEPLOY_LXC_SSH_USER=root
DEPLOY_LXC_SSH_PORT=22

# curl /.commit check after deploy; use public IP until HTTPS + DNS work.
DEPLOY_URL=http://87.117.209.197

# Proxmox / network (same subnet as DomainSage / Road)
DEPLOY_LXC_GW=87.117.209.193
DEPLOY_LXC_BRIDGE=vmbr1
DEPLOY_LXC_STORAGE=local

NAMESERVER_1=87.117.198.200
NAMESERVER_2=87.117.237.100
NAMESERVER_3=87.117.196.200
